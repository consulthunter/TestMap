{
  "RuntimeConfig": {
    "Project": {
      "KeepProjectFiles": true,
      "AnalyzeLatestCommit": false
    },
    "FilePaths": {
      "TargetFilePath": "D:\\Projects\\TestMap\\TestMap\\Data\\example_project.txt",
      "LogsDirPath": "D:\\Projects\\TestMap\\TestMap\\Logs",
      "TempDirPath": "D:\\Projects\\TestMap\\Temp",
      "OutputDirPath": "D:\\Projects\\TestMap\\TestMap\\Output"
    },
    "Docker": {
      "Image": "net-sdk-all",
      "Context": "desktop-linux",
      "WindowsNetwork": "nat"
    },
    "Frameworks": {
      "NUnit": [
        "Test",
        "TestCase",
        "TestCaseSource",
        "Theory"
      ],
      "xUnit": [
        "Fact",
        "Theory"
      ],
      "MSTest": [
        "TestMethod",
        "DataSource"
      ],
      "Microsoft.VisualStudio.TestTools.UnitTesting": [
        "TestMethod",
        "DataSource"
      ]
    },
    "MaxConcurrency": 5,
    "RunDateFormat": "yyyy-MM-dd"
  },
  "TestingConfig": {
    "GenerationConfig": {
      "Objective": "test-suite-expansion",
      "Provider": "custom-openai",
      "Mode": "chat",
      "MetricsPath": "coverage-and-mutation",
      "BudgetMode": "pass-at1-repair-at5",
      "Temperature": 0,
      "StepErrorRetries": 0,
      "StepRetryDelayMs": 1000,
      "ContextMode": "chained-history",
      "TargetSelection": {
        "Strategy": "existing",
        "CandidateLimit": 20,
        "ContextMappingMode": "heuristic-with-grounded-preference"
      },
      "Steps": {
        "EnableEvidencePackage": true,
        "EnableContextGraph": false,
        "EnableContextResolution": false,
        "EnableRoslynValidation": false,
        "EnableScenario": true,
        "EnableMethodName": true,
        "EnableArrangePlan": true,
        "EnableInputPlan": true,
        "EnableActionPlan": true,
        "EnableAssertionPlan": true,
        "EnableFinalTest": true
      },
      "Acceptance": {
        "RequireCompilationSuccess": true,
        "RequireTestsToRun": true,
        "RequireAllTestsPass": true,
        "RequireCoverageImprovement": true,
        "MinCoverageImprovement": 0
      }
    },
    "MetadataEnrichmentConfig": {
      "Enabled": true,
      "UseModel": true,
      "Provider": "custom-openai",
      "Mode": "chat",
      "Temperature": 0.0,
      "RequestDelayMs": 2000,
      "MaxCategories": 3,
      "PromptVersion": "test-metadata-v1"
    },
    "TestingFrameworks": [
      {
        "patterns": [
          "Test",
          "TestCase",
          "TestCaseSource",
          "Theory"
        ]
      },
      {
        "patterns": [
          "Fact",
          "Theory"
        ]
      },
      {
        "patterns": [
          "TestMethod",
          "DataSource"
        ]
      }
    ]
  },
